---
const stats = [
  { value: '4+', label: 'Years experience' },
  { value: '3', label: 'Companies' },
  { value: '5+', label: 'Certifications' },
  { value: '2', label: 'Masters degrees' },
];
---

<section class="hero" id="hero">
  <div class="hero-inner">
    <div class="hero-left">
      <span class="hero-tag hero-fade hero-fade-1">IT Engineer · Madrid, Spain</span>
      <h1 class="hero-name hero-fade hero-fade-2">
        Ángela<br />
        <em>Álvarez</em><br />
        Pérez
      </h1>
      <p class="hero-bio hero-fade hero-fade-3">
        Bridging service management and technology to deliver impactful digital
        solutions — with an Agile mindset and a data-driven approach.
      </p>
      <a href="#experience" class="hero-cta hero-fade hero-fade-4">
        <span>View my work</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
    <div class="hero-right">
      <div class="hero-stats">
        {stats.map(stat => (
          <div class="stat">
            <span class="stat-value" data-count={stat.value}>{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
      <div class="hero-availability">
        <span class="availability-dot" aria-hidden="true"></span>
        <span class="availability-text">Open to new opportunities</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--color-bg);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    min-height: 90vh;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 4rem 5rem 0;
    max-width: 640px;
    margin-left: auto;
  }

  /* Hero entrance animations */
  .hero-fade {
    opacity: 0;
    transform: translateY(24px);
    animation: heroFadeIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-fade-1 { animation-delay: 0.15s; }
  .hero-fade-2 { animation-delay: 0.3s; }
  .hero-fade-3 { animation-delay: 0.5s; }
  .hero-fade-4 { animation-delay: 0.65s; }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 1.75rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .hero-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 1px;
    background-color: var(--color-gold);
  }

  .hero-name {
    font-family: 'DM Serif Display', serif;
    font-size: 4rem;
    line-height: 1.08;
    color: var(--color-ink);
    margin-bottom: 1.75rem;
    letter-spacing: -0.01em;
  }

  .hero-name em {
    color: var(--color-accent);
    font-style: italic;
  }

  .hero-bio {
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
    font-size: 1.125rem;
    color: var(--color-ink-muted);
    line-height: 1.75;
    margin-bottom: 2.5rem;
    max-width: 440px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-white);
    background-color: var(--color-accent);
    padding: 15px 30px;
    border-radius: var(--radius-sm);
    transition: background-color 0.25s, transform 0.25s, box-shadow 0.25s;
    width: fit-content;
  }

  .hero-cta svg {
    transition: transform 0.25s;
  }

  .hero-cta:hover {
    background-color: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(26, 58, 42, 0.2);
  }

  .hero-cta:hover svg {
    transform: translateX(3px);
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background-color: var(--color-accent);
    padding: 4rem 3rem;
    position: relative;
  }

  .hero-right::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(ellipse at 30% 20%, rgba(196, 163, 90, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem 4rem;
    margin-bottom: 3.5rem;
    position: relative;
  }

  .stat {
    text-align: center;
    position: relative;
  }

  .stat-value {
    display: block;
    font-family: 'DM Serif Display', serif;
    font-size: 2.75rem;
    color: var(--color-white);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-availability {
    display: flex;
    align-items: center;
    gap: 10px;
    background-color: rgba(255, 255, 255, 0.08);
    padding: 10px 20px;
    border-radius: 100px;
  }

  .availability-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-green-dot);
    box-shadow: 0 0 8px var(--color-green-dot);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--color-green-dot); }
    50% { opacity: 0.6; box-shadow: 0 0 4px var(--color-green-dot); }
  }

  .availability-text {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.02em;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .availability-dot {
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-left {
      padding: 3.5rem 1.5rem;
      max-width: none;
      margin-left: 0;
    }

    .hero-name {
      font-size: 2.75rem;
    }

    .hero-right {
      padding: 3rem 1.5rem;
    }

    .hero-stats {
      gap: 2rem 3rem;
    }

    .stat-value {
      font-size: 2.25rem;
    }
  }

  @media (max-width: 480px) {
    .hero-left {
      padding: 2.5rem 1rem;
    }

    .hero-name {
      font-size: 2.25rem;
    }

    .hero-bio {
      font-size: 1rem;
    }

    .hero-cta {
      padding: 16px 32px;
      font-size: 1rem;
    }

    .hero-right {
      padding: 2.5rem 1rem;
    }

    .hero-stats {
      gap: 1.5rem 2rem;
    }

    .stat-value {
      font-size: 1.75rem;
    }

    .stat-label {
      font-size: 0.75rem;
    }
  }
</style>
