---
const stats = [
  { value: '4+', label: 'Years' },
  { value: '3', label: 'Companies' },
  { value: '5+', label: 'Certifications' },
  { value: '2', label: 'Masters' },
];
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <div class="hero-inner container">
      <div class="hero-content">
        <span class="hero-tag hero-fade hero-fade-1">IT Engineer · Madrid</span>
        <h1 class="hero-name hero-fade hero-fade-2">
          <span class="name-first">Ángela</span>
          <span class="name-last">Álvarez<br />Pérez</span>
        </h1>
        <p class="hero-bio hero-fade hero-fade-3">
          Bridging service management and technology to deliver impactful digital
          solutions — with an Agile mindset and a data-driven approach.
        </p>
        <div class="hero-actions hero-fade hero-fade-4">
          <a href="#experience" class="hero-cta">
            View my work
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <div class="hero-availability">
            <span class="availability-dot" aria-hidden="true"></span>
            <span class="availability-text">Open to opportunities</span>
          </div>
        </div>
      </div>
      <div class="hero-stats hero-fade hero-fade-4">
        {stats.map(stat => (
          <div class="stat">
            <span class="stat-value" data-count={stat.value}>{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    overflow: hidden;
  }

  .hero-bg {
    background-color: var(--color-bg-dark);
    position: relative;
  }

  .hero-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 15% 80%, rgba(194, 101, 74, 0.12) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 85% 20%, rgba(45, 42, 74, 0.3) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 92vh;
    gap: 4rem;
    position: relative;
  }

  .hero-content {
    max-width: 600px;
    padding: 4rem 0;
  }

  .hero-fade {
    opacity: 0;
    transform: translateY(24px);
    animation: heroFadeIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-fade-1 { animation-delay: 0.2s; }
  .hero-fade-2 { animation-delay: 0.35s; }
  .hero-fade-3 { animation-delay: 0.55s; }
  .hero-fade-4 { animation-delay: 0.7s; }

  @keyframes heroFadeIn {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    margin-bottom: 2rem;
    display: inline-block;
  }

  .hero-name {
    margin-bottom: 2rem;
    line-height: 1;
  }

  .name-first {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.75rem;
  }

  .name-last {
    font-family: 'Playfair Display', serif;
    font-size: 5rem;
    font-weight: 400;
    color: var(--color-white);
    line-height: 1.02;
    display: block;
    letter-spacing: -0.02em;
  }

  .hero-bio {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.8;
    margin-bottom: 2.5rem;
    max-width: 460px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--color-white);
    background-color: var(--color-accent);
    padding: 14px 28px;
    border-radius: 100px;
    transition: background-color 0.25s, transform 0.2s, box-shadow 0.25s;
  }

  .hero-cta svg {
    transition: transform 0.25s;
  }

  .hero-cta:hover {
    background-color: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(194, 101, 74, 0.25);
  }

  .hero-cta:hover svg {
    transform: translateX(3px);
  }

  .hero-availability {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .availability-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-green-dot);
    box-shadow: 0 0 8px var(--color-green-dot);
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .availability-text {
    font-family: 'DM Mono', monospace;
    font-size: 0.6875rem;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.02em;
  }

  /* Stats — vertical strip on the right */
  .hero-stats {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    padding-left: 3rem;
    flex-shrink: 0;
  }

  .stat {
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .stat:last-child {
    border-bottom: none;
  }

  .stat-value {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    color: var(--color-white);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.6875rem;
    color: rgba(255, 255, 255, 0.3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade { opacity: 1; transform: none; animation: none; }
    .availability-dot { animation: none; }
  }

  @media (max-width: 768px) {
    .hero-inner {
      flex-direction: column;
      align-items: flex-start;
      min-height: auto;
      gap: 0;
      padding-top: 3rem;
      padding-bottom: 3rem;
    }

    .hero-content {
      padding: 0;
    }

    .name-last {
      font-size: 3.5rem;
    }

    .hero-stats {
      border-left: none;
      padding-left: 0;
      flex-direction: row;
      gap: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      width: 100%;
      margin-top: 2rem;
    }

    .stat {
      flex: 1;
      text-align: center;
      padding: 1.5rem 0.5rem;
      border-bottom: none;
      border-right: 1px solid rgba(255, 255, 255, 0.06);
    }

    .stat:last-child {
      border-right: none;
    }

    .stat-value {
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    .name-first {
      font-size: 1rem;
    }

    .name-last {
      font-size: 2.5rem;
    }

    .hero-bio {
      font-size: 0.9375rem;
    }

    .hero-cta {
      padding: 14px 26px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }

    .stat-value {
      font-size: 1.5rem;
    }

    .stat-label {
      font-size: 0.625rem;
    }
  }
</style>
