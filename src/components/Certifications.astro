---
const certifications = [
  { name: 'Advanced Scrum Master by SAFe', issuer: 'Scaled Agile Inc.' },
  { name: 'ITIL 4 Foundation Certificate', issuer: '' },
  { name: 'ICAgile Certified Professional', issuer: '' },
  { name: 'SMPC - Scrum Master Professional Certified', issuer: 'EIGP' },
  { name: 'The PowerMBA Future Leaders', issuer: 'Business Management and Administration' },
];
---

<section class="certifications" id="certifications">
  <div class="container certifications-inner">
    <div class="section-header reveal">
      <span class="section-index">05 /</span>
      <h2 class="section-title">Certifications</h2>
      <span class="section-rule"></span>
    </div>
    <div class="cert-grid">
      {certifications.map((cert, i) => (
        <div class="cert-card reveal">
          <span class="cert-num">{String(i + 1).padStart(2, '0')}</span>
          <div class="cert-body">
            <span class="cert-name">{cert.name}</span>
            {cert.issuer && <span class="cert-issuer">{cert.issuer}</span>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .certifications {
    padding: 6rem 0;
    background-color: var(--color-bg);
  }

  .cert-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .cert-grid .cert-card:last-child {
    grid-column: 1 / -1;
  }

  .cert-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1.25rem 1.5rem;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .cert-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
  }

  .cert-num {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--color-accent);
    line-height: 1;
    flex-shrink: 0;
    opacity: 0.5;
  }

  .cert-body {
    padding-top: 2px;
  }

  .cert-name {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-ink);
    display: block;
    line-height: 1.4;
  }

  .cert-issuer {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.8125rem;
    color: var(--color-ink-faint);
    display: block;
    margin-top: 3px;
  }

  @media (max-width: 640px) {
    .cert-grid {
      grid-template-columns: 1fr;
    }

    .cert-grid .cert-card:last-child {
      grid-column: auto;
    }
  }

  @media (max-width: 480px) {
    .certifications {
      padding: 3.5rem 0;
    }

    .cert-card {
      padding: 1rem 1.25rem;
    }
  }
</style>
