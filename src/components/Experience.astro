---
const roles = [
  {
    date: 'Jul 2024 – Present',
    title: 'Service Delivery Manager',
    company: 'Roche',
    location: 'Madrid',
    bullets: [
      'Elaborated Operational Models and contributed to SLAs for Middleware services',
      'Actively managed critical services under external Managed Service model with stakeholders',
      'Led as Scrum Master in achievement of a company OKR',
      'Serving as Scrum Master for a developing product and Project Coordinator for AI productivity projects',
      'Created and tracked performance reports and metrics continuously',
    ],
  },
  {
    date: 'Feb 2024 – Jun 2024',
    title: 'Ecommerce Growth and Analytics',
    company: 'Kimberly-Clark Professional',
    location: 'Remote',
    bullets: [
      'eCommerce data analysis focused on Amazon platform, generating critical business insights',
      'Strategic reports, KPI measurement, and executive presentations for decision-making',
      'Power BI and Tableau for data visualization',
    ],
  },
  {
    date: 'Oct 2022 – Nov 2023',
    title: 'Service Manager',
    company: 'Mercedes-Benz Group Services',
    location: 'Madrid',
    bullets: [
      'Responsible for DOCUWARE service (document automation for pre/sales/after-sales)',
      'Managed electronic signature and payment system; designed document workflows',
      'Main client point of contact: incidents, changes, costs, and risks',
      'Scrum Master role through daily meetings and task updates',
      'ServiceNow and JIRA for workflow tracking',
    ],
  },
  {
    date: 'Oct 2020 – Oct 2022',
    title: 'Community Manager',
    company: 'Escuela de Danza Coppelia',
    location: 'Oviedo',
    bullets: [
      'Managed social media and organized internal community events',
    ],
  },
];
---

<section class="experience" id="experience">
  <div class="container experience-inner">
    <div class="section-header">
      <span class="section-index">02 /</span>
      <h2 class="section-title">Experience</h2>
      <span class="section-rule"></span>
    </div>
    <div class="timeline">
      {roles.map(role => (
        <article class="timeline-item">
          <div class="timeline-date">
            <span>{role.date}</span>
          </div>
          <div class="timeline-card">
            <h3 class="timeline-role">{role.title}</h3>
            <p class="timeline-company">{role.company} · {role.location}</p>
            <ul class="timeline-bullets">
              {role.bullets.map(bullet => (
                <li>{bullet}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    padding: 5rem 0;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
  }

  .timeline-date {
    font-family: 'DM Mono', monospace;
    font-size: 0.8125rem;
    color: var(--color-ink-muted);
    padding-top: 4px;
  }

  .timeline-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .timeline-role {
    font-family: 'DM Serif Display', serif;
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .timeline-company {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin-bottom: 1rem;
  }

  .timeline-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .timeline-bullets li {
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
    padding-left: 1rem;
    position: relative;
  }

  .timeline-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: var(--color-gold);
  }

  @media (max-width: 768px) {
    .timeline-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
