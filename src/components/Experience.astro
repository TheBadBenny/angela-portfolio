---
const roles = [
  {
    date: 'Jul 2024 – Present',
    title: 'Service Delivery Manager',
    company: 'Roche',
    location: 'Madrid, Spain',
    current: true,
    bullets: [
      'Elaborated Operational Models and contributed directly to the creation of Service Level Agreements to ensure quality of service delivery, specifically for Middleware services',
      'Actively managed critical services operated under an external Managed Service model, requiring constant communication and coordination with key internal and external stakeholders',
      'Led as Scrum Master in the achievement of one of the company\'s OKRs, driving agile delivery',
      'Currently serving as Scrum Master for a developing product and Project Coordinator for a team focused on Artificial Intelligence projects for internal productivity',
      'Created and tracked performance reports and metrics continuously',
    ],
  },
  {
    date: 'Feb 2024 – Jun 2024',
    title: 'Ecommerce Growth and Analytics',
    company: 'Kimberly Clark Professional',
    location: 'Remote, Spain',
    current: false,
    bullets: [
      'Conducted eCommerce data analysis, primarily focused on the Amazon platform, generating critical insights for business growth',
      'Prepared strategic reports, measured Key Performance Indicators, and created executive presentations for decision-making',
      'Utilized Power BI and Tableau for data visualization and exploitation',
    ],
  },
  {
    date: 'Oct 2022 – Nov 2023',
    title: 'Service Manager',
    company: 'Mercedes Benz Group Services',
    location: 'Madrid, Spain',
    current: false,
    bullets: [
      'Responsible for the DOCUWARE service, a document automation tool crucial for pre-sales, sales, and after-sales processes',
      'Managed the electronic signature and payment system and designed detailed document workflows',
      'Served as the main point of contact for clients, managing incidents and changes while controlling associated costs and risks',
      'Organized the development team, fulfilling the Scrum Master role through daily meetings and task updates',
      'Utilized ServiceNow and JIRA for workflow tracking and management',
    ],
  },
  {
    date: 'Oct 2020 – Oct 2022',
    title: 'Community Manager',
    company: 'Escuela de Danza Coppelia',
    location: 'Oviedo, Spain',
    current: false,
    bullets: [
      'Managed social media communications and organized internal community events to drive engagement',
    ],
  },
];
---

<section class="experience" id="experience">
  <div class="container experience-inner">
    <div class="section-header reveal">
      <span class="section-index">02 /</span>
      <h2 class="section-title">Experience</h2>
      <span class="section-rule"></span>
    </div>
    <div class="timeline">
      {roles.map(role => (
        <article class="timeline-item reveal">
          <div class="timeline-marker-col">
            <span class={`timeline-dot ${role.current ? 'current' : ''}`}></span>
            <span class="timeline-line"></span>
          </div>
          <div class="timeline-date">
            <span>{role.date}</span>
          </div>
          <div class="timeline-card">
            <h3 class="timeline-role">{role.title}</h3>
            <p class="timeline-company">{role.company} · {role.location}</p>
            <ul class="timeline-bullets">
              {role.bullets.map(bullet => (
                <li>{bullet}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    padding: 6rem 0;
    background-color: var(--color-bg-2);
  }

  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 24px 170px 1fr;
    gap: 0 1.5rem;
  }

  .timeline-item:last-child .timeline-line {
    display: none;
  }

  /* Vertical line + dot */
  .timeline-marker-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 6px;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--color-gold);
    background-color: var(--color-bg-2);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .timeline-dot.current {
    background-color: var(--color-gold);
  }

  .timeline-line {
    width: 1px;
    flex: 1;
    background-color: var(--color-border-strong);
    margin-top: 4px;
  }

  .timeline-date {
    font-family: 'DM Mono', monospace;
    font-size: 0.8125rem;
    color: var(--color-ink-faint);
    padding-top: 4px;
    white-space: nowrap;
  }

  .timeline-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .timeline-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .timeline-role {
    font-family: 'DM Serif Display', serif;
    font-size: 1.25rem;
    margin-bottom: 0.375rem;
    color: var(--color-ink);
  }

  .timeline-company {
    font-family: 'DM Mono', monospace;
    font-weight: 400;
    font-size: 0.8125rem;
    color: var(--color-ink-faint);
    margin-bottom: 1.25rem;
    letter-spacing: 0.01em;
  }

  .timeline-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .timeline-bullets li {
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
    padding-left: 1.125rem;
    position: relative;
    line-height: 1.6;
  }

  .timeline-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--color-gold);
  }

  @media (max-width: 640px) {
    .timeline-item {
      grid-template-columns: 24px 1fr;
    }

    .timeline-date {
      grid-column: 2;
      margin-bottom: 0.25rem;
    }

    .timeline-card {
      grid-column: 2;
    }
  }

  @media (max-width: 480px) {
    .experience {
      padding: 3.5rem 0;
    }

    .timeline-card {
      padding: 1.25rem;
    }

    .timeline-role {
      font-size: 1.125rem;
    }

    .timeline-bullets li {
      font-size: 0.875rem;
    }

    .timeline-card:hover {
      transform: none;
      box-shadow: var(--shadow-sm);
    }
  }
</style>
