---
const skillGroups = [
  {
    title: 'Project & Service Management',
    skills: ['Project Management', 'Incident Management', 'Problem Resolution', 'Team Organization', 'Agile', 'Scrum', 'SAFe', 'ITIL 4'],
  },
  {
    title: 'Data & Development',
    skills: ['Python', 'Big Data', 'Power BI', 'Tableau'],
  },
  {
    title: 'Tools',
    skills: ['ServiceNow', 'JIRA', 'Office Suite'],
  },
];
---

<section class="skills" id="skills">
  <div class="container skills-inner">
    <div class="section-header reveal">
      <span class="section-index">03 /</span>
      <h2 class="section-title">Skills</h2>
      <span class="section-rule"></span>
    </div>
    <div class="skill-groups">
      {skillGroups.map(group => (
        <div class="skill-group reveal">
          <h3 class="skill-group-title">{group.title}</h3>
          <div class="skill-chips">
            {group.skills.map(skill => (
              <span class="chip">{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills {
    padding: 6rem 0;
    background-color: var(--color-bg);
  }

  .skill-groups {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem 4rem;
  }

  .skill-groups .skill-group:first-child {
    grid-column: 1 / -1;
  }

  .skill-group-title {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.6875rem;
    margin-bottom: 1rem;
    color: var(--color-ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .chip {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.8125rem;
    color: var(--color-ink-muted);
    background-color: var(--color-white);
    border: 1px solid var(--color-border-strong);
    padding: 10px 18px;
    border-radius: 100px;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: default;
  }

  .chip:hover {
    background-color: var(--color-indigo);
    border-color: var(--color-indigo);
    color: var(--color-white);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(45, 42, 74, 0.15);
  }

  @media (max-width: 640px) {
    .skill-groups {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .skills {
      padding: 3.5rem 0;
    }

    .chip {
      padding: 8px 14px;
    }
  }
</style>
