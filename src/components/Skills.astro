---
const skillGroups = [
  {
    title: 'Project & Service Management',
    skills: ['Project Management', 'Incident Management', 'Problem Resolution', 'Team Organization', 'Agile', 'Scrum', 'SAFe', 'ITIL 4'],
  },
  {
    title: 'Data & Development',
    skills: ['Python', 'Big Data', 'Power BI', 'Tableau'],
  },
  {
    title: 'Tools',
    skills: ['ServiceNow', 'JIRA', 'Office Suite'],
  },
];
---

<section class="skills" id="skills">
  <div class="container skills-inner">
    <div class="section-header reveal">
      <span class="section-index">03 /</span>
      <h2 class="section-title">Skills</h2>
      <span class="section-rule"></span>
    </div>
    <div class="skill-groups">
      {skillGroups.map(group => (
        <div class="skill-group reveal">
          <h3 class="skill-group-title">{group.title}</h3>
          <div class="skill-chips">
            {group.skills.map(skill => (
              <span class="chip">{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills {
    padding: 6rem 0;
    background-color: var(--color-bg);
  }

  .skill-groups {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .skill-group-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.125rem;
    margin-bottom: 1.25rem;
    color: var(--color-ink);
  }

  .skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .chip {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 0.8125rem;
    color: var(--color-ink-muted);
    background-color: transparent;
    border: 1px solid var(--color-border-strong);
    padding: 9px 18px;
    border-radius: 100px;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: default;
    letter-spacing: 0.01em;
  }

  .chip:hover {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-white);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(26, 58, 42, 0.15);
  }

  @media (max-width: 480px) {
    .skills {
      padding: 3.5rem 0;
    }

    .chip {
      padding: 8px 14px;
      font-size: 0.8125rem;
    }
  }
</style>
