---
const education = [
  {
    degree: 'Master in Management, Innovation & Decision Making',
    institution: 'European University Miguel de Cervantes',
    dates: '2022 – 2023',
  },
  {
    degree: 'Master in Big Data & Data Science',
    institution: 'Complutense University of Madrid',
    dates: '2021 – 2022',
  },
  {
    degree: "Bachelor's Degree in Computer Engineering & IT",
    institution: 'University of Oviedo',
    dates: '2016 – 2021',
  },
];
---

<section class="education" id="education">
  <div class="container education-inner">
    <div class="section-header reveal">
      <span class="section-index">04 /</span>
      <h2 class="section-title">Education</h2>
      <span class="section-rule"></span>
    </div>
    <div class="education-grid">
      {education.map((item, i) => (
        <article class={`education-card reveal reveal-delay-${i + 1}`}>
          <div class="education-accent" aria-hidden="true"></div>
          <div class="education-body">
            <span class="education-dates">{item.dates}</span>
            <h3 class="education-degree">{item.degree}</h3>
            <p class="education-institution">{item.institution}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .education {
    padding: 6rem 0;
    background-color: var(--color-bg-2);
  }

  .education-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .education-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .education-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .education-accent {
    height: 3px;
    background: linear-gradient(to right, var(--color-gold), var(--color-accent));
  }

  .education-body {
    padding: 1.5rem;
  }

  .education-dates {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: var(--color-gold);
    letter-spacing: 0.04em;
    display: block;
    margin-bottom: 0.75rem;
  }

  .education-degree {
    font-family: 'DM Serif Display', serif;
    font-size: 1.0625rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .education-institution {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 0.8125rem;
    color: var(--color-ink-faint);
  }

  @media (max-width: 768px) {
    .education-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .education {
      padding: 3.5rem 0;
    }

    .education-grid {
      grid-template-columns: 1fr;
    }

    .education-body {
      padding: 1.25rem;
    }

    .education-degree {
      font-size: 1rem;
    }

    .education-card:hover {
      transform: none;
      box-shadow: var(--shadow-sm);
    }
  }
</style>
