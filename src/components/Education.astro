---
const education = [
  {
    degree: 'Master in Management, Innovation & Decision Making',
    institution: 'European University Miguel de Cervantes',
    dates: '2022 – 2023',
  },
  {
    degree: 'Master in Big Data & Data Science',
    institution: 'Complutense University of Madrid',
    dates: '2021 – 2022',
  },
  {
    degree: "Bachelor's Degree in Computer Engineering & IT",
    institution: 'University of Oviedo',
    dates: '2016 – 2021',
  },
];
---

<section class="education" id="education">
  <div class="container education-inner">
    <div class="section-header">
      <span class="section-index">04 /</span>
      <h2 class="section-title">Education</h2>
      <span class="section-rule"></span>
    </div>
    <div class="education-grid">
      {education.map(item => (
        <article class="education-card">
          <h3 class="education-degree">{item.degree}</h3>
          <p class="education-institution">{item.institution}</p>
          <span class="education-dates">{item.dates}</span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .education {
    padding: 5rem 0;
  }

  .education-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .education-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .education-degree {
    font-family: 'DM Serif Display', serif;
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }

  .education-institution {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin-bottom: 0.75rem;
  }

  .education-dates {
    font-family: 'DM Mono', monospace;
    font-size: 0.8125rem;
    color: var(--color-ink-faint);
  }

  @media (max-width: 768px) {
    .education-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .education-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
