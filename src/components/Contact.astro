---
const languages = [
  { lang: 'Spanish', level: 'Native' },
  { lang: 'English', level: 'Advanced/C1' },
  { lang: 'French', level: 'Elementary' },
];
---

<section class="languages" id="languages">
  <div class="container languages-inner">
    <div class="section-header reveal">
      <span class="section-index">06 /</span>
      <h2 class="section-title">Languages</h2>
      <span class="section-rule"></span>
    </div>
    <div class="lang-row reveal reveal-delay-1">
      {languages.map(item => (
        <div class="lang-card">
          <span class="lang-name">{item.lang}</span>
          <span class="lang-level">{item.level}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="contact" id="contact">
  <div class="contact-wrapper">
    <div class="container contact-inner">
      <span class="contact-tag reveal">07 / Get in touch</span>
      <h2 class="contact-headline reveal reveal-delay-1">
        Let's build something<br />worth shipping.
      </h2>
      <div class="contact-links reveal reveal-delay-2">
        <a href="mailto:aangelap19198@gmail.com" class="contact-link-item">
          aangelap19198@gmail.com
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 12L12 4M12 4H6M12 4v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="tel:+34636843243" class="contact-link-item">
          +34 636 843 243
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 12L12 4M12 4H6M12 4v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <span class="contact-link-item location">Madrid, Spain</span>
      </div>
      <div class="contact-social reveal reveal-delay-3">
        <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile">LinkedIn</a>
        <span class="social-dot" aria-hidden="true"></span>
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile">GitHub</a>
      </div>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container footer-inner">
    <p>&copy; 2026 Ángela Álvarez Pérez · Madrid, Spain</p>
  </div>
</footer>

<style>
  /* Languages */
  .languages {
    padding: 6rem 0;
    background-color: var(--color-bg-2);
  }

  .lang-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .lang-card {
    flex: 1;
    min-width: 160px;
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow-sm);
  }

  .lang-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.125rem;
    color: var(--color-ink);
    display: block;
    margin-bottom: 0.25rem;
  }

  .lang-level {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.8125rem;
    color: var(--color-ink-faint);
  }

  /* Contact */
  .contact-wrapper {
    background-color: var(--color-bg-dark);
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
  }

  .contact-wrapper::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 50% at 80% 70%, rgba(194, 101, 74, 0.1) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 10% 30%, rgba(45, 42, 74, 0.25) 0%, transparent 50%);
    pointer-events: none;
  }

  .contact-inner {
    position: relative;
  }

  .contact-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    display: block;
    margin-bottom: 1.5rem;
  }

  .contact-headline {
    font-family: 'Playfair Display', serif;
    font-size: 3.5rem;
    color: var(--color-white);
    margin-bottom: 3rem;
    line-height: 1.12;
    max-width: 600px;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 2.5rem;
  }

  .contact-link-item {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 44px;
    width: fit-content;
    transition: color 0.2s;
  }

  .contact-link-item svg {
    opacity: 0;
    transform: translate(-4px, 4px);
    transition: opacity 0.2s, transform 0.2s;
  }

  a.contact-link-item:hover {
    color: var(--color-white);
  }

  a.contact-link-item:hover svg {
    opacity: 1;
    transform: translate(0, 0);
  }

  .contact-link-item.location {
    color: rgba(255, 255, 255, 0.3);
  }

  .contact-social {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .contact-social a {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.45);
    transition: color 0.2s;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  .contact-social a:hover {
    color: var(--color-white);
  }

  .social-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.2);
  }

  /* Footer */
  .footer {
    padding: 2rem 0;
    background-color: var(--color-bg-dark);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-inner p {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.2);
    text-align: center;
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .contact-headline {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .languages {
      padding: 3.5rem 0;
    }

    .contact-wrapper {
      padding: 3.5rem 0;
    }

    .contact-headline {
      font-size: 1.75rem;
    }

    .lang-card {
      padding: 1rem 1.25rem;
    }
  }
</style>
